{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "eslint-plugin-nitpick",
  "version": "0.12.2",
  "description": "An ESLint plugin for nitpicky rules.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "release": "npm run build && changeset publish",
    "build:docs": "eslint-doc-generator",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ej-shafran/eslint-plugin-nitpick.git"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "javascript",
    "typescript"
  ],
  "author": "ej-shafran",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ej-shafran/eslint-plugin-nitpick/issues"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0"
  },
  "homepage": "https://github.com/ej-shafran/eslint-plugin-nitpick#readme",
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@commitlint/types": "21.0.0",
    "@eslint/js": "10.0.1",
    "@types/estree": "1.0.9",
    "@types/node": "22.19.8",
    "eslint": "10.3.0",
    "eslint-doc-generator": "3.3.2",
    "eslint-plugin-eslint-plugin": "7.3.3",
    "eslint-plugin-n": "18.0.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.5"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
